              "enum": [
                "total",
                "female",
                ""
              ]
            }
          },
          {
            "name": "Age Group",
            "type": "string",
            "constraints": {
              "enum": [
                "all",
                "15-49",
                ""
              ]
            }
          },
          {
            "name": "Geography",
            "type": "string",
            "constraints": {
              "enum": [
                "national",
                "rural",
                ""
              ]
            }
          },
          {
            "name": "Value",
            "type": "number"
          }
        ]
      }
    }
  ],
  "profile": "data-package",
  "name": "1-1-1",
